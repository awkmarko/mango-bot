# URL Ollama servisa (lokalno ili na udaljenom serveru)
OLLAMA_BASE_URL=http://localhost:11434

# Naziv modela koji Ollama koristi
OLLAMA_MODEL=gemma2:9b

# Maksimalan broj poruka koje se čuvaju u istoriji razgovora (u parovima korisnik/bot)
MAX_HISTORY_TURNS=20

# Adresa MySQL servera
MYSQL_HOST=localhost

# Port MySQL servera (standardno 3306)
MYSQL_PORT=3306

# Korisničko ime za MySQL
MYSQL_USER=root

# Lozinka za MySQL
MYSQL_PASSWORD=your_password_here

# Naziv baze podataka
MYSQL_DATABASE=clickshop

# Model za generisanje embeddings-a (mora biti dostupan u Ollama)
EMBEDDING_MODEL=nomic-embed-text

# Putanja do ChromaDB direktorijuma za čuvanje vektora
CHROMA_DB_PATH=./chroma_db
